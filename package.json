{
  "name": "kairos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "api:sync-specs": "node ./scripts/sync-openapi-specs.mjs",
    "api:generate": "npm run api:sync-specs && openapi-ts",
    "api:generate:watch": "openapi-ts --watch",
    "api:check": "node -e \"const fs=require('node:fs'); const ok=(value)=> value.startsWith('http') ? fetch(value).then((response)=>{ if(!response.ok) throw new Error(value); }) : Promise.resolve(fs.accessSync(value, fs.constants.R_OK)); Promise.all([ok(process.env.OPENAPI_POSEIDON_INPUT || './.cache-specs/poseidon/openapi.json'), ok(process.env.OPENAPI_TRITON_INPUT || './.cache-specs/triton/openapi.json')]).catch((error)=>{ console.error(error.message); process.exit(1); });\"",
    "deploy:stormtrooper": "bash ./scripts/deploy-stormtrooper.sh",
    "smoke:prod": "bash ./scripts/smoke-prod.sh"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@hey-api/openapi-ts": "^0.87.0",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/eslint-plugin-query": "^5.90.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
