:80 {
  route {
    handle_path /poseidon/* {
      reverse_proxy host.docker.internal:8001 {
        header_up X-API-Key {$POSEIDON_API_KEY}
      }
    }

    handle_path /triton/* {
      reverse_proxy host.docker.internal:8000
    }

    handle_path /thalassa/* {
      reverse_proxy 192.168.31.241:8001 {
        header_up X-API-Key {$THALASSA_API_KEY}
      }
    }

    root * /srv/kairos
    try_files {path} /index.html
    file_server
  }
}
